# Copy to .env to customise. ALL OPTIONAL — the suite runs fully without any of these.

# Turn on the optional LLM healing tier (default: false).
SELF_HEAL_LLM=false

# Required ONLY when SELF_HEAL_LLM=true.
# ANTHROPIC_API_KEY=sk-ant-...

# Model used by the LLM tier (default: claude-sonnet-4-6).
# SELF_HEAL_MODEL=claude-sonnet-4-6

# Persist + replay healed recipes across runs (default: true).
# SELF_HEAL_CACHE=true

# Where cache + reports are written (default: .self-heal).
# SELF_HEAL_ARTIFACTS=.self-heal
